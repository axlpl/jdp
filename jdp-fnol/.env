REACT_APP_JUTRO_LOGGER_LEVEL=WARN
SKIP_PREFLIGHT_CHECK=true
DISABLE_NEW_JSX_TRANSFORM=true

# E2E related env vars
DEPLOY_URL=http://localhost:3000

DISABLE_ESLINT_PLUGIN=true
FAST_REFRESH=false

JUTRO_REACT_STRICT_MODE=true
JUTRO_DISABLE_AUTO_EVENTS_PUBLISHING=true
JUTRO_DISABLE_AUTO_INIT_ANALYTICS=true
JUTRO_NEW_CONFIG_LOADING_ORDER=true

# ====== JDP FNOL runtime config ======
# Flip to false when real PC/CC endpoints are reachable + auth works.
REACT_APP_USE_MOCKS=true

# Base URLs for Guidewire Cloud API
REACT_APP_POLICY_CENTER_BASE_URL=http://localhost:8180
REACT_APP_CLAIM_CENTER_BASE_URL=http://localhost:8280

# Optional bearer token forwarded to PC/CC (dev only).
# Leave empty when using OAuth2/OIDC via @jutro/auth.
REACT_APP_API_BEARER_TOKEN=
