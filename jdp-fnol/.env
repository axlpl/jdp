REACT_APP_JUTRO_LOGGER_LEVEL=WARN
SKIP_PREFLIGHT_CHECK=true
DISABLE_NEW_JSX_TRANSFORM=true
DEPLOY_URL=http://localhost:3000
DISABLE_ESLINT_PLUGIN=true
FAST_REFRESH=false
JUTRO_REACT_STRICT_MODE=true
JUTRO_DISABLE_AUTO_EVENTS_PUBLISHING=true
JUTRO_DISABLE_AUTO_INIT_ANALYTICS=true
JUTRO_NEW_CONFIG_LOADING_ORDER=true

# JDP FNOL
# Secrets/URLs live in .env.local (gitignored). See .env.example for the template.
REACT_APP_USE_MOCKS=true
REACT_APP_POLICY_CENTER_BASE_URL=/pc
REACT_APP_CLAIM_CENTER_BASE_URL=/cc
REACT_APP_API_AUTH_MODE=basic
REACT_APP_API_BASIC_USER=
REACT_APP_API_BASIC_PASSWORD=
REACT_APP_API_BEARER_TOKEN=

# Webpack dev proxy targets (used by src/setupProxy.js) - override in .env.local.
PC_PROXY_TARGET=
CC_PROXY_TARGET=
