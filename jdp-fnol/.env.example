# ─────────────────────────────────────────────────────────────
# JDP FNOL — environment template
# Copy to `.env` or `.env.local` and fill in secrets.
# Never commit `.env` / `.env.local` (they're already in .gitignore).
# Webpack reads these at `npm start` — restart the dev server after changes.
# ─────────────────────────────────────────────────────────────

# ─── Jutro platform defaults (leave as-is) ───
REACT_APP_JUTRO_LOGGER_LEVEL=WARN
SKIP_PREFLIGHT_CHECK=true
DISABLE_NEW_JSX_TRANSFORM=true
DEPLOY_URL=http://localhost:3000
DISABLE_ESLINT_PLUGIN=true
FAST_REFRESH=false
JUTRO_REACT_STRICT_MODE=true
JUTRO_DISABLE_AUTO_EVENTS_PUBLISHING=true
JUTRO_DISABLE_AUTO_INIT_ANALYTICS=true
JUTRO_NEW_CONFIG_LOADING_ORDER=true


# ─── JDP FNOL runtime config ───

# Flip to `false` to hit real PolicyCenter + ClaimCenter instead of in-memory mocks.
REACT_APP_USE_MOCKS=true

# Guidewire Cloud API base URLs.
# IMPORTANT: Use the host only (no trailing `/PolicyCenter.do` or `/ClaimCenter.do`).
# Cloud API lives at `{baseUrl}/rest/...`. If your deployment exposes it under a
# sub-path (e.g. `/pc/rest/...`), append that path here.
#
# Example values for the Guidewire CP dev/test tenant:
#   REACT_APP_POLICY_CENTER_BASE_URL=https://pc-datatest-gwcpdev.icpei.alpha3-butterfly.guidewire.net
#   REACT_APP_CLAIM_CENTER_BASE_URL=https://cc-datatest-gwcpdev.icpei.alpha3-butterfly.guidewire.net
REACT_APP_POLICY_CENTER_BASE_URL=http://localhost:8180
REACT_APP_CLAIM_CENTER_BASE_URL=http://localhost:8280


# ─── Auth mode ───
# Pick ONE of: `bearer` | `oauth` | `basic` | `none`.
#   bearer → forwards `Authorization: Bearer ${REACT_APP_API_BEARER_TOKEN}` on every call
#   oauth  → expects `@jutro/auth` (OIDC/Okta) to inject the token via transport handler
#   basic  → forwards `Authorization: Basic base64(user:pass)` — local Tomcat only
#   none   → no auth header; only useful when a BFF handles auth server-side
REACT_APP_API_AUTH_MODE=none


# ─── Bearer token auth (REACT_APP_API_AUTH_MODE=bearer) ───
# Dev token from Artifactory / Identity provider. NEVER commit.
REACT_APP_API_BEARER_TOKEN=


# ─── Basic auth (REACT_APP_API_AUTH_MODE=basic) ───
# Only for a locally-run PC/CC Tomcat. NEVER use in production.
REACT_APP_API_BASIC_USER=
REACT_APP_API_BASIC_PASSWORD=


# ─── OAuth2 / OIDC (REACT_APP_API_AUTH_MODE=oauth) ───
# Driven by `@jutro/auth`. Requires wiring `<AuthProvider>` in startApp.ts
# (currently disabled — flip when you go with real OAuth).
REACT_APP_JUTRO_AUTH_ENABLED=false
REACT_APP_JUTRO_AUTH_ISSUER=
REACT_APP_JUTRO_AUTH_CLIENT_ID=
REACT_APP_JUTRO_AUTH_SCOPE=openid,profile,email
REACT_APP_JUTRO_AUTH_REDIRECT_PATH=/auth/callback


# ─── CORS NOTE ───
# The browser will block direct calls to *.guidewire.net from http://localhost:3000
# unless the PC/CC instances return `Access-Control-Allow-Origin: http://localhost:3000`.
# If you get a CORS error:
#   1) Confirm the dev tenant whitelists `http://localhost:3000` in its CORS config, OR
#   2) Use a local dev proxy (webpack-dev-server `proxy` option), OR
#   3) Put a small BFF (Node/Java) in front of PC/CC.
