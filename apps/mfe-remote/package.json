  "scripts": {
    "eslint-v9": "npx -y eslint-v9@npm:eslint@^9 ./**/*.{js,jsx,mjs,json}",
    "sass": "sass --watch src/themes/scss:src/themes/css",
    "start": "run-s \"start-*\"",
    "start-info": "npm run write-build-info",
    "start-i18n": "npm run i18n",
    "start-webpack": "cross-env jutro app:start --no-verify",
    "build": "run-s \"build-*\"",
    "build-info": "npm run write-build-info",
    "build-i18n": "npm run i18n",
    "build-themes": "jutro generate:themes",
    "build-webpack": "cross-env GENERATE_SOURCEMAP=false jutro app:build --no-verify",
    "depcheck": "jutro validate:dependencies",
    "i18n": "rimraf i18n && jutro generate:i18n",
    "write-build-info": "jutro generate:buildInfo",
    "update-cli": "jutro update:cli",
    "update-app": "npm run update-cli && jutro update:app",
    "test": "jutro app:tests --no-verify",
    "test:ci": "cross-env CI=true npm test --collectCoverage",
    "prepack": "node prepack.js",
    "postpack": "node postpack.js",
    "validate-file-structure": "jutro validate:folders",
    "lint:js": "cross-env eslint -c .eslintrc.js './**/*.{js,jsx,mjs,json,ts,tsx}'",
    "lint:css": "cross-env stylelint \"**/*.scss\"",
    "lint:html": "cross-env html-validate './**/*.html'",
    "lint": "cross-env run-s lint:*",
    "prettier": "cross-env prettier --write -c '**/*.{ts,tsx,js,json,scss,html}'",
    "prettier-check": "cross-env prettier --check -c '**/*.{ts,tsx,js,json,scss,html}'",
    "prettier-check-files": "cross-env prettier --check",
    "changelog": "jutro generate:changelog",
    "serve:dist": "npx serve -s -p 6006 dist"
  },
  "browserslist": [
    "extends @jutro/browserslist-config"
  ],
  "devDependencies": {
    "@babel/core": "7.26.10",
    "@commitlint/config-conventional": "17.8.1",
